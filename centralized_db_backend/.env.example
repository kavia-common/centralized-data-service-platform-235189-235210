# Backend
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# REQUIRED for JWT auth
JWT_SECRET=change_me

# Public base URL (optional, recommended when behind a proxy/gateway)
# Used by /docs to set OpenAPI "servers" URL consistently.
PUBLIC_BASE_URL=

# DB (provided by DB container)
# Preferred: supply a full connection string (either DATABASE_URL or POSTGRES_URL)
DATABASE_URL=
POSTGRES_URL=

# If no URL is provided, the backend will construct a connection from parts.
# These are typically injected by the database container/runtime:
POSTGRES_HOST=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=5001

# Common Postgres aliases are also supported as fallback:
PGHOST=
PGUSER=
PGPASSWORD=
PGDATABASE=
PGPORT=

# Rate limiting
RATE_LIMIT_WINDOW_S=60
RATE_LIMIT_MAX=100

# CORS
# Comma-separated list. Use explicit origins for dashboard auth flows.
# Example: ALLOWED_ORIGINS=http://localhost:3000,https://my-dashboard.example.com
# If you set '*', credentials will be disabled automatically.
ALLOWED_ORIGINS=http://localhost:3000
ALLOWED_HEADERS=Content-Type,Authorization
ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_MAX_AGE=3600

# Logging
LOG_LEVEL=debug
LOG_PRETTY=true
