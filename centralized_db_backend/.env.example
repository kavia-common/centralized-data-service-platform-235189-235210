# Backend
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# REQUIRED for JWT auth
JWT_SECRET=change_me

# DB (provided by DB container)
POSTGRES_URL=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=5001

# Rate limiting
RATE_LIMIT_WINDOW_S=60
RATE_LIMIT_MAX=100

# CORS
ALLOWED_ORIGINS=http://localhost:3000
ALLOWED_HEADERS=Content-Type,Authorization
ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_MAX_AGE=3600

# Logging
LOG_LEVEL=debug
LOG_PRETTY=true
